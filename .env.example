# Optional public URL for a trusted server-side AI proxy.
# Use a full URL or a same-origin serverless path such as /api/ai.
VITE_AI_API_URL=

# Optional. Requests fall back to deterministic demo mode after this duration.
VITE_AI_REQUEST_TIMEOUT_MS=6000

# Server-only example for a future proxy. Vite does not expose variables without
# the VITE_ prefix to browser code. Never rename this to VITE_AI_PROVIDER_API_KEY.
AI_PROVIDER_API_KEY=
